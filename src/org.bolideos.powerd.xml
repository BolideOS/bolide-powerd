<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
  "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="org.bolideos.powerd.ProfileManager">
    <!-- Profile management methods -->
    <method name="GetProfiles">
      <arg name="profiles" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <method name="GetActiveProfile">
      <arg name="profileId" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <method name="SetActiveProfile">
      <arg name="id" type="s" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>

    <method name="GetProfile">
      <arg name="id" type="s" direction="in"/>
      <arg name="profile" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <method name="UpdateProfile">
      <arg name="profileJson" type="s" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>

    <method name="AddProfile">
      <arg name="profileJson" type="s" direction="in"/>
      <arg name="newId" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <method name="DeleteProfile">
      <arg name="id" type="s" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>

    <!-- Workout methods -->
    <method name="StartWorkout">
      <arg name="workoutType" type="s" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>

    <method name="StopWorkout">
      <arg name="success" type="b" direction="out"/>
    </method>

    <method name="GetWorkoutProfiles">
      <arg name="workoutProfiles" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <method name="SetWorkoutProfile">
      <arg name="workoutType" type="s" direction="in"/>
      <arg name="profileId" type="s" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>

    <!-- Battery telemetry methods -->
    <method name="GetBatteryHistory">
      <arg name="hours" type="i" direction="in"/>
      <arg name="history" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <method name="GetBatteryPrediction">
      <arg name="prediction" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <method name="GetBatteryHealth">
      <arg name="healthInfo" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <method name="GetCurrentState">
      <arg name="state" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <!-- Sensor access coordination methods -->
    <method name="RequestSensorAccess">
      <arg name="sensorName" type="s" direction="in"/>
      <arg name="minIntervalMs" type="i" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>

    <method name="ReleaseSensorAccess">
      <arg name="sensorName" type="s" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>

    <method name="GetAvailableSensors">
      <arg name="sensors" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <method name="GetActiveSensorGrants">
      <arg name="grants" type="s" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QString"/>
    </method>

    <!-- Signals -->
    <signal name="ActiveProfileChanged">
      <arg name="id" type="s"/>
      <arg name="name" type="s"/>
    </signal>

    <signal name="ProfilesChanged"/>

    <signal name="WorkoutStarted">
      <arg name="workoutType" type="s"/>
      <arg name="profileId" type="s"/>
    </signal>

    <signal name="WorkoutStopped"/>

    <signal name="BatteryLevelChanged">
      <arg name="level" type="i"/>
      <arg name="charging" type="b"/>
    </signal>

    <signal name="BatteryHealthChanged">
      <arg name="healthPercent" type="i"/>
      <arg name="learnedMah" type="i"/>
      <arg name="designMah" type="i"/>
    </signal>

    <signal name="SensorAccessGranted">
      <arg name="sensorName" type="s"/>
      <arg name="effectiveIntervalMs" type="i"/>
    </signal>

    <signal name="SensorAccessReleased">
      <arg name="sensorName" type="s"/>
    </signal>
  </interface>
</node>
